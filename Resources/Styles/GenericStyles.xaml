<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="Base" TargetType="{x:Type ContentControl}">
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="BaseTextBlock" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="GenericButton" BasedOn="{StaticResource Base}" TargetType="Button">
        <Setter Property="MinHeight" Value="25"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{StaticResource GenericButtonBackground}"/>
    </Style>

    <Style x:Key="PathButton" BasedOn="{StaticResource Base}" TargetType="Button">
        <Setter Property="MinHeight" Value="16"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="Background" Value="{StaticResource GenericButtonBackground}"/>
    </Style>

    <Style x:Key="ImportantButton" BasedOn="{StaticResource Base}" TargetType="Button">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{StaticResource GenericButtonBackground}"/>
    </Style>

    <Style x:Key="GenericTabEntry" BasedOn="{StaticResource Base}" TargetType="TabItem">
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="TextBlockHeader1" BasedOn="{StaticResource BaseTextBlock}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <Style x:Key="TextBlockHeader2" BasedOn="{StaticResource BaseTextBlock}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <Style x:Key="TextBlockHeader3" BasedOn="{StaticResource BaseTextBlock}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

</ResourceDictionary>